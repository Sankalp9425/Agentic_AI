# =============================================================================
# Agentic AI Framework — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys and settings.
# Only configure the providers you plan to use.

# -----------------------------------------------------------------------------
# LLM Provider API Keys
# -----------------------------------------------------------------------------

# OpenAI (GPT-4, GPT-4o, GPT-3.5-turbo)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini (Gemini Pro, Gemini Ultra)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Anthropic Claude (Claude 3 Opus, Sonnet, Haiku)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Groq (LLaMA, Mixtral — ultra-fast inference)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# Embedding Provider Keys (if different from chat keys)
# -----------------------------------------------------------------------------

# Voyage AI embeddings (recommended for Anthropic/Claude users)
# Get your key at: https://dash.voyageai.com/
VOYAGE_API_KEY=

# -----------------------------------------------------------------------------
# Vector Database Configuration
# -----------------------------------------------------------------------------

# ChromaDB (local/in-memory — no config needed for default)
CHROMA_PERSIST_DIRECTORY=./chroma_data

# Pinecone (managed cloud vector DB)
# Get your key at: https://app.pinecone.io/
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE=

# PostgreSQL + pgvector
PGVECTOR_CONNECTION_STRING=postgresql://user:password@localhost:5432/vectordb

# FAISS (local in-memory — no config needed)
FAISS_INDEX_PATH=./faiss_index

# -----------------------------------------------------------------------------
# MCP Connector Configuration
# -----------------------------------------------------------------------------

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Google Custom Search
# Set up at: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# -----------------------------------------------------------------------------
# API Server Configuration
# -----------------------------------------------------------------------------

# Server settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# RAG Pipeline Defaults
# -----------------------------------------------------------------------------

RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_CHUNKER_TYPE=recursive
RAG_RETRIEVER_TYPE=simple
RAG_TOP_K=5
RAG_EXTRACT_IMAGES=true
RAG_EXTRACT_TABLES=true

# -----------------------------------------------------------------------------
# General Settings
# -----------------------------------------------------------------------------

# Maximum retries for API calls
MAX_RETRIES=3

# Request timeout in seconds
REQUEST_TIMEOUT=30

# Enable debug mode (verbose logging)
DEBUG=false
